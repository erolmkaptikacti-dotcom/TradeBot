# Optional. Enables the "Solana Top Traders" section on the Top Traders
# tab (real wallet PnL via Birdeye). Get a key at https://birdeye.so — their
# trader-analytics endpoints require a paid plan, not just the free tier.
# Without this set, that section shows a setup prompt instead of data.
BIRDEYE_API_KEY=

# Optional. Overrides the Polymarket trader-leaderboard URL used by the Copy
# Trading tab. The route already tries the known public hosts (lb-api and
# data-api) automatically, so you only need this if those move again. The
# positions endpoint (data-api.polymarket.com/positions) needs no config and
# no auth — reading Polymarket data is public and NOT geoblocked; only
# placing real trades is restricted, which this app never does.
POLYMARKET_LEADERBOARD_URL=
